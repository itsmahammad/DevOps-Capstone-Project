{
  "annotations": { "list": [] },
  "title": "Request Rate & Saturation",
  "uid": "request-rate-saturation",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["resumeats", "saturation"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests per Second",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"resumeats-prod\"}[1m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "CPU Usage per Pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"resumeats-prod\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },
    {
      "id": 3,
      "title": "Memory Usage per Pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"resumeats-prod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "HPA Replicas",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "kube_hpa_status_current_replicas{namespace=\"resumeats-prod\"}",
          "legendFormat": "current: {{hpa}}",
          "refId": "A"
        },
        {
          "expr": "kube_hpa_status_desired_replicas{namespace=\"resumeats-prod\"}",
          "legendFormat": "desired: {{hpa}}",
          "refId": "B"
        }
      ]
    }
  ]
}