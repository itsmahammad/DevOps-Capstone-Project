# =============================================================================
# .env.example — Resume-ATS environment variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ---- Backend (FastAPI) ----
# Port the backend listens on inside the container
PORT=8000
# Bind address (0.0.0.0 = all interfaces)
HOST=0.0.0.0
# Debug mode (set to false in production)
DEBUG=false
# App metadata (read by /health endpoint)
APP_NAME=ATS Resume Analyzer
APP_VERSION=1.0.0
# Max upload size in MB
MAX_FILE_SIZE_MB=5
# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.pdf,.docx
# CORS allowed origins (comma-separated, * = allow all)
CORS_ORIGINS=*

# ---- Frontend (Next.js) ----
# Backend API URL the frontend proxies /api/* requests to.
# In Docker Compose: http://backend:8000
# In Kubernetes: http://backend.resumeats-prod.svc.cluster.local:80
# Local dev (no Docker): http://localhost:8000
NEXT_PUBLIC_API_URL=http://backend:8000

# =============================================================================
# The following are used by CI/CD and Terraform — store as GitHub secrets/vars.
# They are NOT needed for local `docker compose up` development.
# =============================================================================

# ---- Azure / GitHub OIDC (GitHub Actions) ----
# Azure tenant ID (directory ID)
AZURE_TENANT_ID=
# Azure subscription ID
AZURE_SUBSCRIPTION_ID=
# Azure AD App Registration client ID (created by github-oidc Terraform module)
AZURE_CLIENT_ID=
# Azure AD App Registration client secret (only if OIDC is not used; prefer OIDC)
AZURE_CLIENT_SECRET=

# ---- Azure Container Registry ----
# ACR name (e.g. acrresumeatsprod)
ACR_NAME=
# ACR login server (e.g. acrresumeatsprod.azurecr.io)
ACR_LOGIN_SERVER=

# ---- Azure SQL (provisioned but not yet used by the app) ----
# SQL admin password is generated by Terraform and stored in Key Vault.
# Do NOT set it here — it is managed via Azure Key Vault + CSI Secret Store.
SQL_ADMIN_PASSWORD=

# ---- Kubernetes (for kubectl deploy from GitHub Actions) ----
# Base64-encoded kubeconfig for the AKS cluster
KUBECONFIG=