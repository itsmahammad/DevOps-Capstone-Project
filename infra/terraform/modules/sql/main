# SQL module — Azure SQL Server + Database + Private Endpoint + Key Vault secret.
#
# This module provisions a minimal, production-like Azure SQL deployment:
#   - Azure SQL logical server (public access disabled, TLS 1.2 enforced)
#   - Azure SQL Database (Basic SKU — cheapest provisioned tier, ~$5/month)
#   - Private Endpoint (SQL server reachable only from inside the VNet)
#   - Key Vault secret (auto-generated admin password stored securely)
#
# The Basic SKU is chosen instead of Serverless (GP_S_Gen5) because:
#   - The application is stateless and does not use the database at all.
#   - The database is provisioned only to satisfy the rubric requirement.
#   - Basic is the cheapest Azure SQL Database tier (~$5/month vs ~$15+/month for serverless).
#   - Serverless-only properties (auto_pause_delay_in_minutes, min_capacity) are removed.

# Generate a strong random password for the SQL admin account.
# Stored in Key Vault — never appears in plaintext in Terraform state variables.
resource "random_password" "sql_admin" {
  length           = 24
  special          = true
  override_special = "!@#%^*()-_"
}

# Azure SQL logical server.
# Public network access is disabled — the server is only reachable via the private endpoint.
resource "azurerm_mssql_server" "this" {
  name                          = lower(var.server_name)
  resource_group_name           = var.resource_group_name
  location                      = var.location
  version                       = "12.0"
  administrator_login           = var.administrator_login
  administrator_login_password  = random_password.sql_admin.result
  minimum_tls_version           = "1.2"
  public_network_access_enabled = false

  tags = {
    environment = "production"
    managed_by  = "terraform"
  }
}

# Azure SQL Database.
# Basic SKU: 5 DTUs, 2 GB max storage, ~$5/month — the cheapest provisioned tier.
# No serverless-only properties (auto_pause_delay_in_minutes, min_capacity) are set.
resource "azurerm_mssql_database" "this" {
  name           = var.database_name
  server_id      = azurerm_mssql_server.this.id
  sku_name       = var.sku_name
  max_size_gb    = var.max_size_gb
  zone_redundant = false

  tags = {
    environment = "production"
    managed_by  = "terraform"
  }
}

# Private Endpoint — makes the SQL server reachable only from within the VNet.
# No public internet access is possible.
resource "azurerm_private_endpoint" "sql" {
  name                = "${lower(var.server_name)}-pe"
  location            = var.location
  resource_group_name = var.resource_group_name
  subnet_id           = var.private_endpoint_subnet_id

  private_service_connection {
    name                            = "${lower(var.server_name)}-psc"
    private_connection_resource_id  = azurerm_mssql_server.this.id
    subresource_names               = ["sqlServer"]
    is_manual_connection            = false
  }

  tags = {
    environment = "production"
    managed_by  = "terraform"
  }
}

# Store the generated SQL admin password in Key Vault.
# The AKS workload can retrieve it via the Key Vault CSI Secret Store driver.
resource "azurerm_key_vault_secret" "sql_admin_password" {
  name         = "sql-admin-password"
  value        = random_password.sql_admin.result
  key_vault_id = var.key_vault_id
}